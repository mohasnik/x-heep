name: "openhwgroup.org:ip:cv32e40p"
description: "OpenHW Group RISC-V Core CV32E40P"

filesets:
  files_rtl:
    depend:
    - pulp-platform.org::fpnew
    files:
    - openhwgroup/cv32e40p/rtl/include/cv32e40p_apu_core_pkg.sv
    - openhwgroup/cv32e40p/rtl/include/cv32e40p_fpu_pkg.sv
    - openhwgroup/cv32e40p/rtl/include/cv32e40p_pkg.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_alu.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_alu_div.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_ff_one.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_popcnt.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_compressed_decoder.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_controller.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_cs_registers.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_decoder.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_int_controller.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_ex_stage.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_hwloop_regs.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_id_stage.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_if_stage.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_load_store_unit.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_mult.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_prefetch_buffer.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_prefetch_controller.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_obi_interface.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_aligner.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_sleep_unit.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_core.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_apu_disp.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_fifo.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_fp_wrapper.sv
    - openhwgroup/cv32e40p/rtl/cv32e40p_top.sv
    file_type: systemVerilogSource


  files_clk_gate:
    files:
    - openhwgroup/cv32e40p/bhv/cv32e40p_sim_clock_gate.sv
    file_type: systemVerilogSource

  ff_regfile:
    files:
    - openhwgroup/cv32e40p/rtl/cv32e40p_register_file_ff.sv
    file_type: systemVerilogSource

  latch_regfile:
    files:
    - openhwgroup/cv32e40p/rtl/cv32e40p_register_file_latch.sv
    file_type: systemVerilogSource

targets:
  default:
    filesets:
    - files_rtl
    - ff_regfile
    - target_sim? (files_clk_gate)
    - target_sim_sc? (files_clk_gate)
