### synch cells Constraints


foreach cell [get_cells -hier -filter {ORIG_REF_NAME=="sync" || REF_NAME=="sync"}] {
set_max_delay -through [get_pins -filter {NAME=~"*reg_q_reg[0]/D"} -of_objects [get_cells null/*]] 20.000
set_false_path -hold -through [get_pins -filter {NAME=~"*reg_q_reg[0]/D"} -of_objects [get_cells null/*]]
}


create_property INIT cell -type string
set_property IOB FALSE [get_cells xilinx_ps_wizard_wrapper_i/xilinx_ps_wizard_i/axi_quad_spi/U0/NO_DUAL_QUAD_MODE.QSPI_NORMAL/IO0_I_REG]
